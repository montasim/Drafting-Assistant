{
  "name": "thoughtline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "wxt",
    "prepare": "wxt prepare && husky",
    "build": "wxt build",
    "zip": "wxt zip",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "wxt build && playwright test",
    "test:visual": "wxt build && playwright test tests/e2e/visual.spec.ts tests/e2e/onboarding.spec.ts",
    "test:prototype": "wxt build && playwright test tests/e2e/visual.spec.ts tests/e2e/onboarding.spec.ts --grep \"approved prototype\"",
    "test:journey": "wxt build && playwright test tests/e2e/user-journeys.spec.ts tests/e2e/onboarding.spec.ts",
    "test:ai": "vitest run tests/quality/ai-response-quality.test.ts",
    "test:ai:live": "vitest run tests/quality/live-ai-quality.test.ts",
    "check:ui": "playwright test",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "release:zip": "pnpm check && wxt zip"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@fontsource/noto-sans": "^5.2.8",
    "@fontsource/noto-sans-bengali": "^5.3.0",
    "@fontsource/roboto-mono": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "charter-webfont": "^4.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "pdfjs-dist": "^5.4.149",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.62.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.2.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@wxt-dev/module-react": "^1.2.2",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "wxt": "^0.20.27"
  }
}
